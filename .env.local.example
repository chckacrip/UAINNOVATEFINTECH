# Client-side (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (Lambda / API routes)
# These take priority over NEXT_PUBLIC_ variants in server code.
# In Lambda, set these directly — no NEXT_PUBLIC_ prefix needed.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=sk-your-openai-api-key

# Plaid (optional — for bank account auto-import)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# Email digest (optional — for weekly AI digest)
CRON_SECRET=your-cron-secret
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=FinanceCopilot <digest@financecopilot.app>
